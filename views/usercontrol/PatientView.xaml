<UserControl x:Class="NolMed.views.usercontrol.PatientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NolMed.views.usercontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <TextBlock Text="{Binding WelcomeText}"
           VerticalAlignment="Top"
           HorizontalAlignment="Left"
           FontSize="24" Margin="30,30,0,0"/>

        <TextBlock HorizontalAlignment="Left" Margin="27,67,0,0" TextWrapping="Wrap" Text="Room:" VerticalAlignment="Top" FontSize="18"/>
        <ComboBox HorizontalAlignment="Left" 
                  Margin="83,69,0,0" 
                  VerticalAlignment="Top"
                  Width="120" 
                  SelectedItem="{Binding SelectedRoom, UpdateSourceTrigger=PropertyChanged}" 
                  ItemsSource="{Binding RoomPicker}"/>

        <Grid Background="#80000000" Visibility="{Binding IsPopupVisible}" Margin="200, 100">
            <Border Background="White" Width="300" Height="180">
                <StackPanel Margin="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Grid.Row="0" Text="First name:" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Grid.Row="0" Text="{Binding FirstNameInput}" Margin="0,5"/>

                        <TextBlock Grid.Column="0" Grid.Row="1" Text="Last name:" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Grid.Row="1" Text="{Binding LastNameInput}" Margin="0,5"/>

                        <TextBlock Grid.Column="0" Grid.Row="2" Text="Dob:" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Grid.Row="2" Text="{Binding DobInput}" Margin="0,5"/>

                        <Button Grid.ColumnSpan="2" Grid.Row="3" Content="Find patient" Command="{Binding SearchPatientByName}" Margin="0,5"/>

                        <Button Grid.ColumnSpan="2" Grid.Row="4" Content="Cancel" Command="{Binding CancelPopup}"/>
                    </Grid>

                </StackPanel>
            </Border>
        </Grid>

        <TextBlock HorizontalAlignment="Left" Margin="30,96,0,0" TextWrapping="Wrap" Text="Patient Info" VerticalAlignment="Top" FontSize="16"/>
        <TextBlock HorizontalAlignment="Left" Margin="30,122,0,0" TextWrapping="Wrap" Text="{Binding PatientName}" VerticalAlignment="Top"/>
        <TextBlock HorizontalAlignment="Left" Margin="30,143,0,0" TextWrapping="Wrap" Text="{Binding PatientDob}" VerticalAlignment="Top"/>
        <TextBlock HorizontalAlignment="Left" Margin="30,164,0,0" TextWrapping="Wrap" Text="{Binding BloodType}" VerticalAlignment="Top"/>

        <TextBlock HorizontalAlignment="Left" Margin="30,190,0,0" TextWrapping="Wrap" Text="Insurance" VerticalAlignment="Top" FontSize="16"/>
        <TextBlock HorizontalAlignment="Left" Margin="30,218,0,0" TextWrapping="Wrap" Text="Number:" VerticalAlignment="Top"/>
        <TextBox HorizontalAlignment="Left" Margin="83,216,0,0" TextWrapping="Wrap" Text="{Binding InsuranceNumber}" VerticalAlignment="Top" Width="120"/>
        <TextBlock HorizontalAlignment="Left" Margin="30,238,0,0" TextWrapping="Wrap" Text="Name:" VerticalAlignment="Top"/>
        <TextBox HorizontalAlignment="Left" Margin="83,236,0,0" TextWrapping="Wrap" Text="{Binding InsuranceName}" VerticalAlignment="Top" Width="120"/>

        <TextBlock HorizontalAlignment="Left" Margin="30,271,0,0" TextWrapping="Wrap" Text="Allergies" VerticalAlignment="Top" FontSize="16"/>
        <ListBox ItemsSource="{Binding AllergiesList}" HorizontalAlignment="Left" VerticalAlignment="Top" Height="60" Width="176" Margin="27,297,0,0"/>
        <Button Content="Add allergy" HorizontalAlignment="Left" Margin="27,362,0,0" VerticalAlignment="Top" Command="{Binding AddAllergy}"/>
        <Button Content="Remove" HorizontalAlignment="Left" Margin="157,362,0,0" VerticalAlignment="Top" Command="{Binding RemoveAllergy}"/>

        <TextBlock HorizontalAlignment="Left" Margin="400,96,0,0" TextWrapping="Wrap" Text="Address" VerticalAlignment="Top" FontSize="16"/>
        <TextBlock HorizontalAlignment="Left" Margin="400,122,0,0" TextWrapping="Wrap" Text="Street:" VerticalAlignment="Top"/>
        <TextBox HorizontalAlignment="Left" Margin="464,120,0,0" TextWrapping="Wrap" Text="{Binding StreetName}" VerticalAlignment="Top" Width="120"/>
        <TextBlock HorizontalAlignment="Left" Margin="400,143,0,0" TextWrapping="Wrap" Text="City:" VerticalAlignment="Top"/>
        <TextBox HorizontalAlignment="Left" Margin="464,141,0,0" TextWrapping="Wrap" Text="{Binding CityName}" VerticalAlignment="Top" Width="120"/>
        <TextBlock HorizontalAlignment="Left" Margin="400,164,0,0" TextWrapping="Wrap" Text="State:" VerticalAlignment="Top"/>
        <TextBox HorizontalAlignment="Left" Margin="464,162,0,0" TextWrapping="Wrap" Text="{Binding StateName}" VerticalAlignment="Top" Width="120"/>
        <TextBlock HorizontalAlignment="Left" Margin="400,185,0,0" TextWrapping="Wrap" Text="Zip:" VerticalAlignment="Top"/>
        <TextBox HorizontalAlignment="Left" Margin="464,183,0,0" TextWrapping="Wrap" Text="{Binding ZipName}" VerticalAlignment="Top" Width="120"/>
        <TextBlock HorizontalAlignment="Left" Margin="400,206,0,0" TextWrapping="Wrap" Text="Country:" VerticalAlignment="Top"/>
        <TextBox HorizontalAlignment="Left" Margin="464,204,0,0" TextWrapping="Wrap" Text="{Binding CountryName}" VerticalAlignment="Top" Width="120"/>

        <TextBlock HorizontalAlignment="Left" Margin="400,246,0,0" TextWrapping="Wrap" Text="Reason for visit" VerticalAlignment="Top" FontSize="16"/>
        <RichTextBox Margin="400,272,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" MaxHeight="100" MaxWidth="300" Height="100" Width="300">
            <FlowDocument>
                <Paragraph>
                    <Run Text="Reason"/>
                </Paragraph>
            </FlowDocument>
        </RichTextBox>
    </Grid>
</UserControl>
