<UserControl x:Class="NolMed.views.usercontrol.PatientVitalsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NolMed.views.usercontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">
    <Grid>
        <TextBlock Text="{Binding PlaceholderText}"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Left"
                   FontSize="24" Margin="10,10,0,0"/>

        <Grid VerticalAlignment="Top" HorizontalAlignment="Left" Background="#1E1E1E" Height="290" Width="442" Margin="10,42,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Heart rate monitor" Foreground="White" FontSize="18" Margin="10"/>

            <lvc:CartesianChart 
                Grid.Row="1" 
                Series="{Binding ChartSeries}" 
                DisableAnimations="True" 
                Hoverable="False"
                Background="Black"
                Foreground="LimeGreen"
                DataTooltip="{x:Null}">

                <lvc:CartesianChart.AxisX>
                    <lvc:Axis Title="" ShowLabels="False"/>
                </lvc:CartesianChart.AxisX>

                <lvc:CartesianChart.AxisY>
                    <lvc:Axis Title="Bpm" MinValue="{Binding YMin}" MaxValue="{Binding YMax}" Foreground="LightGray"/>
                </lvc:CartesianChart.AxisY>

            </lvc:CartesianChart>
        </Grid>

        <TextBlock VerticalAlignment="Top" HorizontalAlignment="Left" Margin="494,42,0,0" TextWrapping="Wrap" Text="Blood Pressure" FontSize="16"/>
        <Label Content="{Binding BloodPressureSys}" HorizontalAlignment="Left" Margin="494,78,0,0" VerticalAlignment="Top"/>
        <Label Content="/" HorizontalAlignment="Left" Margin="537,78,0,0" VerticalAlignment="Top"/>
        <Label Content="{Binding BloodPressureDia}" HorizontalAlignment="Left" Margin="557,78,0,0" VerticalAlignment="Top"/>
    </Grid>
</UserControl>
