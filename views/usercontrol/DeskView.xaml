<UserControl x:Class="NolMed.views.usercontrol.DeskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NolMed.views.usercontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <TextBlock Text="{Binding WelcomeMessage}" 
                   FontSize="24" 
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Top" Margin="36,21,0,0"/>
        <TextBlock Text="Lookup patient by last name: " 
                   FontSize="14" 
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Top" Margin="36,61,0,0"/>
        <TextBlock Text="Lookup patient by room number: " 
                   FontSize="14" 
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Top" Margin="36,76,0,0"/>
    </Grid>
</UserControl>
