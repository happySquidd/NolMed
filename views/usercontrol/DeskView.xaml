<UserControl x:Class="NolMed.views.usercontrol.DeskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NolMed.views.usercontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <TextBlock Text="{Binding WelcomeMessage}" 
                   FontSize="24" 
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Top" Margin="36,21,0,0"/>
        <TextBlock Text="Check in the patient" 
                   FontWeight="Bold"
                   FontSize="14" 
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Top" Margin="36,61,0,0"/>
        <TextBlock Text="Last name: " 
                   FontSize="14" 
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Top" Margin="36,81,0,0"/>
        <TextBox HorizontalAlignment="Left" 
                 Margin="111,82,0,0" 
                 TextWrapping="NoWrap" 
                 Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" 
                 VerticalAlignment="Top" Width="86"/>
        <TextBlock Text="First name: " 
                   FontSize="14" 
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Top" Margin="211,81,0,0"/>
        <TextBox HorizontalAlignment="Left" 
                 Margin="286,82,0,0" 
                 TextWrapping="NoWrap" 
                 Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" 
                 VerticalAlignment="Top" Width="86"/>
        <Button Content="Enter" 
                Margin="382,81,0,0" 
                HorizontalAlignment="Left" 
                VerticalAlignment="Top" 
                Width="40" 
                Command="{Binding AssignPatient}"/>

        <Grid Margin="20, 110, 20, 20">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding PatientRooms}">

                    
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="200" Height="120"
                                    Background="{Binding BackgroundColor}"
                                    Margin="10"
                                    Command="{Binding DataContext.RoomBoxClicked, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">

                                <Grid Width="200" Height="120">
                                    <TextBlock Text="{Binding RoomNumber}" 
                                           Foreground="White" 
                                           FontSize="16"
                                           HorizontalAlignment="Left" 
                                           VerticalAlignment="Top"
                                               Margin="10"/>
                                    <TextBlock Text="{Binding RoomName}"
                                           Foreground="White" 
                                           FontSize="16"
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding PatientName}"
                                               Foreground="White" 
                                               FontSize="16"
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"
                                               Margin="0,35,0,0"/>
                                </Grid>
                                
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </ScrollViewer>
        </Grid>
        <Button Content="Refresh" HorizontalAlignment="Left" Margin="427,81,0,0" VerticalAlignment="Top" Command="{Binding RefreshList}" Width="50"/>
    </Grid>
</UserControl>
